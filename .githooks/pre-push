#!/bin/bash
# Pre-push hook: auto-bump package.json to match version tags.
#
# When pushing a version tag (v1.2.3), this hook checks if package.json
# matches. If not, it updates package.json, commits, re-tags, and asks
# the user to push again.

while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$local_ref" =~ ^refs/tags/v([0-9]+\.[0-9]+\.[0-9]+.*)$ ]]; then
    tag_version="${BASH_REMATCH[1]}"
    pkg_version=$(node -p "require('./package.json').version")

    if [[ "$tag_version" != "$pkg_version" ]]; then
      echo ""
      echo "⚠️  Tag version (${tag_version}) ≠ package.json (${pkg_version})"
      echo "   Auto-bumping package.json → ${tag_version}"

      node -e "
        const fs = require('fs');
        const pkg = JSON.parse(fs.readFileSync('package.json', 'utf8'));
        pkg.version = '${tag_version}';
        fs.writeFileSync('package.json', JSON.stringify(pkg, null, 2) + '\n');
      "

      git add package.json
      git commit -m "chore: bump version to ${tag_version}

Co-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>"

      git tag -fa "v${tag_version}" -m "Release v${tag_version}"

      echo ""
      echo "   ✅ Version bumped to ${tag_version}."
      echo "   Run this again: git push origin main v${tag_version}"
      echo ""
      exit 1
    fi
  fi
done

exit 0
