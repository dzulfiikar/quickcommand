{
  "name": "quickcommand",
  "version": "1.1.0",
  "private": true,
  "description": "macOS menubar command and text snippet launcher built with Electron, TypeScript, and Bun.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "bun run build:helper && electron-vite dev",
    "dev:browser": "vite --config vite.browser.config.ts",
    "preview": "bun run build:helper && electron-vite preview",
    "build": "electron-vite build",
    "build:helper": "bun run scripts/build-helper.ts",
    "package:dir": "bun run build:helper -- --force && bun run build && electron-builder --dir",
    "dist": "bun run build:helper -- --force && bun run build && electron-builder",
    "release": "bun run build:helper -- --force && bun run build && electron-builder",
    "version:bump": "bun run scripts/bump-version.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "prepare": "git config core.hooksPath .githooks"
  },
  "build": {
    "appId": "com.personal.quickcommand",
    "productName": "QuickCommand",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "trayTemplate.png",
          "trayTemplate@2x.png"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icons/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": true
      },
      "electronLanguages": [
        "en"
      ]
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "framer-motion": "^12.35.2",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
