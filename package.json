{
  "name": "quickcommand",
  "version": "0.1.0",
  "private": true,
  "description": "macOS menubar command and text snippet launcher built with Electron, TypeScript, and Bun.",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "bun run build:helper && electron-vite dev",
    "preview": "bun run build:helper && electron-vite preview",
    "build": "electron-vite build",
    "build:helper": "bun run scripts/build-helper.ts",
    "package:dir": "bun run build:helper && bun run build && electron-builder --dir",
    "dist": "bun run build:helper && bun run build && electron-builder",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "build": {
    "appId": "com.personal.quickcommand",
    "productName": "QuickCommand",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist-native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "trayTemplate.png",
          "trayTemplate@2x.png"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icons/icon.icns",
      "target": [
        "dir"
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    }
  },
  "dependencies": {
    "fuse.js": "^7.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "bun-types": "^1.3.10",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3"
  }
}
